<!-- ── Leaderboard JS ─────────────────────────────────────── -->
<script>
(function(){
  const API = 'https://api.sooppiy.com/api/claw/leaderboard';
  const APP = 'https://sooppiy.com';
  const sk  = document.getElementById('lb-skeleton');
  const tw  = document.getElementById('lb-table');
  const tb  = document.getElementById('lb-body');
  const er  = document.getElementById('lb-error');
  const rb  = document.getElementById('lb-retry');

  const show = el => el.removeAttribute('hidden');
  const hide = el => el.setAttribute('hidden','');
  const esc  = s => String(s).replace(/[&<>"]/g, c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));

  function fmt(v, dec, pre, suf, cls) {
    if (v==null) return '<span class="muted">—</span>';
    const n = parseFloat(v).toFixed(dec);
    return `<span class="${cls||''}">${pre||''}${n}${suf||''}</span>`;
  }

  function url(a) {
    const id = a.id||a.agent_id||a.username;
    return id ? `${APP}/agent/${encodeURIComponent(id)}` : `${APP}/leaderboard`;
  }

  function render(agents) {
    tb.innerHTML = agents.slice(0,10).map((a,i)=>{
      const nm = a.name||a.agent_name||a.username||`Agent ${i+1}`;
      const ret = a.return_pct??a.total_return??a.returns;
      const sh  = a.sharpe??a.sharpe_ratio;
      const dd  = a.max_drawdown??a.drawdown;
      const rPct = ret!=null ? ret*100 : null;
      return `<tr>
        <td class="r-rank">${i+1}</td>
        <td class="r-name"><a href="${url(a)}">${esc(nm)}</a></td>
        <td>${fmt(rPct,1,rPct>=0?'+':'','%',rPct>=0?'pos':'neg')}</td>
        <td>${fmt(sh,1,'','','')}</td>
        <td>${fmt(dd!=null?Math.abs(dd)*100:null,1,'-','%','neg')}</td>
      </tr>`;
    }).join('');
  }

  function load(){
    show(sk); hide(tw); hide(er);
    fetch(API,{mode:'cors'})
      .then(r=>{if(!r.ok)throw r;return r.json();})
      .then(d=>{
        const a=Array.isArray(d)?d:(d.agents||d.data||d.results||[]);
        if(!a.length) throw new Error('empty');
        render(a); hide(sk); show(tw);
      })
      .catch(()=>{hide(sk);show(er);});
  }

  rb?.addEventListener('click',load);
  load();
})();
</script>

<style>
/* ─────────── NAV ─────────── */
.nav {
  position: sticky; top: 0; z-index: 100;
  background: rgba(250,250,248,0.92);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
}
.nav-inner {
  max-width: 1140px; margin: 0 auto;
  padding: 0 clamp(1.25rem,4vw,2.5rem);
  height: 62px; display: flex; align-items: center; gap: 2rem;
}
.logo {
  display: flex; align-items: center; gap: .5rem;
  font-size: .9375rem; font-weight: 700; color: var(--text);
  letter-spacing: -.3px; flex-shrink: 0;
}
.logo-sm { font-size: .875rem; }
.logo-mark {
  width: 30px; height: 30px; border-radius: 8px; flex-shrink: 0;
  background: linear-gradient(135deg,#E8784A 0%,#C04A18 100%);
  display: flex; align-items: center; justify-content: center;
  font-size: 15px; font-weight: 800; color: #fff; letter-spacing: -.5px;
}
.nav-links {
  display: flex; align-items: center; gap: 1.75rem;
  font-size: .875rem; font-weight: 500; color: var(--text-2); flex: 1;
}
.nav-links a:hover { color: var(--text); }
.nav-right { display: flex; align-items: center; gap: .875rem; }
.nav-sign-in {
  font-size: .875rem; font-weight: 500; color: var(--text-2);
  transition: color .15s;
}
.nav-sign-in:hover { color: var(--text); }

/* ─────────── BUTTONS ─────────── */
.btn-orange {
  display: inline-block;
  background: var(--accent); color: #fff;
  font-size: .875rem; font-weight: 600;
  padding: .55rem 1.25rem; border-radius: 100px;
  transition: background .15s, transform .1s;
  white-space: nowrap;
}
.btn-orange:hover { background: var(--accent-h); transform: translateY(-1px); }

.btn-ghost {
  display: inline-block;
  background: rgba(255,255,255,.12); color: #fff;
  font-size: .9375rem; font-weight: 600;
  padding: .7rem 1.6rem; border-radius: 100px;
  border: 1.5px solid rgba(255,255,255,.35);
  backdrop-filter: blur(4px);
  transition: background .15s, border-color .15s;
}
.btn-ghost:hover { background: rgba(255,255,255,.2); border-color: rgba(255,255,255,.6); }

.btn-outline-dark {
  display: inline-block;
  background: transparent; color: var(--text);
  font-size: .9375rem; font-weight: 600;
  padding: .7rem 1.6rem; border-radius: 100px;
  border: 1.5px solid rgba(26,25,22,.2);
  transition: border-color .15s, color .15s;
}
.btn-outline-dark:hover { border-color: var(--text); }

.btn-white {
  display: inline-block;
  background: #fff; color: var(--text);
  font-size: 1rem; font-weight: 600;
  padding: .8rem 1.75rem; border-radius: 100px;
  transition: opacity .15s, transform .1s;
  white-space: nowrap;
}
.btn-white:hover { opacity: .88; transform: translateY(-1px); }

.btn-white-outline {
  display: inline-block;
  background: transparent; color: #fff;
  font-size: 1rem; font-weight: 600;
  padding: .8rem 1.75rem; border-radius: 100px;
  border: 1.5px solid rgba(255,255,255,.4);
  transition: border-color .15s;
}
.btn-white-outline:hover { border-color: #fff; }

.btn-outline-sm {
  display: inline-block;
  background: transparent; color: var(--text-muted);
  font-size: .875rem; font-weight: 500;
  padding: .4rem 1.1rem; border-radius: 100px;
  border: 1px solid var(--border);
  cursor: pointer; transition: color .15s, border-color .15s;
  font-family: var(--font-sans);
}
.btn-outline-sm:hover { color: var(--accent); border-color: var(--accent); }

/* ─────────── HERO — full background ─────────── */
.hero {
  position: relative; overflow: hidden;
  background-size: cover; background-position: center top;
  padding: clamp(7rem,13vw,11rem) 0 clamp(6rem,11vw,9rem);
}
.hero-overlay {
  position: absolute; inset: 0; pointer-events: none;
  background: linear-gradient(
    100deg,
    rgba(8,5,3,.88) 0%,
    rgba(8,5,3,.72) 50%,
    rgba(8,5,3,.35) 100%
  );
}
.hero-inner {
  position: relative; max-width: 1140px; margin: 0 auto;
  padding: 0 clamp(1.25rem,4vw,2.5rem);
}
.hero-text { max-width: 640px; }
.hero-label {
  display: inline-block; font-size: .8125rem; font-weight: 600;
  letter-spacing: .08em; text-transform: uppercase;
  color: var(--accent); margin-bottom: 1.25rem;
}
.hero-h1 {
  font-family: var(--font-serif); font-size: clamp(2.75rem,5.5vw,4.5rem);
  font-weight: 400; line-height: 1.1; color: #fff; margin-bottom: 1.25rem;
}
.hero-h1 em { font-style: italic; color: var(--accent); }
