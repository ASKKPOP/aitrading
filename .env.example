# ==================== Environment ====================
ENVIRONMENT=development

# ==================== Database ====================
# MySQL takes precedence when DATABASE_URL is set.
# Leave empty for local SQLite development.
DATABASE_URL=
# Example MySQL URL (requires mysql+pymysql:// scheme):
# DATABASE_URL=mysql+pymysql://ai_trader:change-me@127.0.0.1:3306/ai_trader

# SQLite fallback path when DATABASE_URL is empty.
DB_PATH=service/server/data/aitrad.db

# ==================== API Keys ====================
ALPHA_VANTAGE_API_KEY=demo

# ==================== Redis (optional — enables cross-process rate limits & auth codes) ====================
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=ai_trader

# ==================== Email (optional — enables transactional verification codes) ====================
# Sign up at https://resend.com and verify your sending domain.
RESEND_API_KEY=
EMAIL_FROM=noreply@sooppiy.com

# ==================== Frontend ====================
# Frontend auto-refresh interval in milliseconds.
VITE_REFRESH_INTERVAL=300000

# ==================== Network / CORS ====================
AITRAD_CORS_ORIGINS=http://localhost:3000,https://app.sooppiy.com,https://sooppiy.com

# ==================== Market Data Endpoints ====================
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query
HYPERLIQUID_API_URL=https://api.hyperliquid.xyz/info
POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_BASE_URL=https://clob.polymarket.com

# ==================== Background Tasks ====================
# AI_TRADER_WORKER_ROLE — one of: all (default), prices, settlement, research
# Run multiple worker processes side-by-side, one per role, to scale roles
# independently. Each role uses its own singleton lock so they coexist.
# AI_TRADER_WORKER_ROLE=all

POSITION_REFRESH_INTERVAL=300
MAX_PARALLEL_PRICE_FETCH=5
POLYMARKET_SETTLE_INTERVAL=60
MARKET_NEWS_REFRESH_INTERVAL=900
MACRO_SIGNAL_REFRESH_INTERVAL=900
ETF_FLOW_REFRESH_INTERVAL=900
STOCK_ANALYSIS_REFRESH_INTERVAL=1800

# ==================== Profit History Retention ====================
# Keep recent history at full resolution.
PROFIT_HISTORY_FULL_RESOLUTION_HOURS=24

# Keep compacted history inside this rolling window.
PROFIT_HISTORY_COMPACT_WINDOW_DAYS=7

# Bucket size used when compacting older profit history.
PROFIT_HISTORY_COMPACT_BUCKET_MINUTES=15

# Minimum interval between prune/compact passes.
PROFIT_HISTORY_PRUNE_INTERVAL_SECONDS=3600

# ==================== Price Fetch Reliability ====================
PRICE_FETCH_TIMEOUT_SECONDS=10
PRICE_FETCH_MAX_RETRIES=2
PRICE_FETCH_BACKOFF_BASE_SECONDS=0.35
PRICE_FETCH_ERROR_COOLDOWN_SECONDS=20
PRICE_FETCH_RATE_LIMIT_COOLDOWN_SECONDS=60

# ==================== Broker Execution Layer (Phase 2) ====================
# Alpaca — paper trading sandbox (set ALPACA_PAPER=false for live)
ALPACA_KEY=
ALPACA_SECRET=
ALPACA_PAPER=true

# Binance — testnet (set BINANCE_TESTNET=false for live)
BINANCE_KEY=
BINANCE_SECRET=
BINANCE_TESTNET=true

# AES-GCM key for encrypting broker credentials at rest.
# Generate: python -c "from execution.crypto import generate_key_b64; print(generate_key_b64())"
EXECUTION_ENCRYPTION_KEY=
