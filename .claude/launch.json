{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": ".venv/bin/python",
      "runtimeArgs": ["-m", "uvicorn", "--app-dir", "service/server", "main:app", "--host", "127.0.0.1", "--port", "8001"],
      "port": 8001
    },
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "service/frontend",
      "port": 3000
    }
  ]
}
