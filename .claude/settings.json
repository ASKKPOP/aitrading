{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "git push 2>&1 || true",
            "statusMessage": "Pushing to origin...",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
