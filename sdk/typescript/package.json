{
  "name": "@sooppiy/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Sooppiy agent-native trading platform",
  "keywords": ["sooppiy", "sooppiy", "trading", "ai-agent", "copy-trading", "signals"],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./schema": {
      "types": "./dist/schema.d.ts"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "generate": "openapi-typescript spec.json -o src/schema.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "openapi-fetch": "^0.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "openapi-typescript": "^7.4.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "homepage": "https://sooppiy.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/ASKKPOP/aitrading"
  }
}
